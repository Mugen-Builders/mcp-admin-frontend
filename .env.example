# Cartesi Admin Web (Vite) — copy to `.env` or `.env.local` for local development.

# Base URL of the Admin API (no trailing slash). Used for Vite dev/build and, in the Docker
# image, for both `window.__APP_CONFIG__` and nginx `proxy_pass` (see docker-entrypoint.sh).
VITE_ADMIN_API_BASE_URL=http://localhost:8000
