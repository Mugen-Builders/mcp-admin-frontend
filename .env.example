# Cartesi Admin Web (Vite) — copy to `.env` or `.env.local` for local development.

# Base URL of the Admin API (no trailing slash). Used when building API requests in the browser.
VITE_ADMIN_API_BASE_URL=http://localhost:8000

# --- Docker / production container ---
# The static nginx image injects runtime config from `env.template.js` using env substitution.
# Set this in the container environment (e.g. `infra` compose `admin-web.env`), not in Vite:
# ADMIN_API_BASE_URL=https://api.example.com
