# Cartesi Admin Web (Vite) — copy to `.env` or `.env.local` for local development.

# Base URL of the Admin API (no trailing slash). Must include http:// or https:// — required for
# nginx `proxy_pass` in the container. Used for Vite dev/build, `window.__APP_CONFIG__`, and the proxy.
ADMIN_API_BASE_URL=http://localhost:8000
